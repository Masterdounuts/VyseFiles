# OpenClaw Workspace .gitignore
# ===========================================
# OBSIDIAN EXCLUSIONS (manual vault settings)
# Exclude these folders in Obsidian: Vault Settings → Files & Links → Excluded folders
# - bin/           # Bot scripts, not notes
# - config/        # Config files
# - cron/          # Cron jobs
# - scripts/       # Operational scripts
# - obsidian-prototype/  # Migration templates
# - logs/          # Log files
# - tmp/           # Temp files
# - state/         # Bot state
# - .openclaw/     # OpenClaw data
# - .github/       # GitHub workflows
# ===========================================

# Dependencies
node_modules/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Local OpenClaw data (don't commit)
.openclaw/
state/
.vyse-*.txt
headline-requests.json

# Obsidian vault (user-specific)
.obsidian/

# Binaries (install system-wide)
bin/

# Bootstrap/reference files (committed separately)
# AGENTS.md
# SOUL.md
# MEMORY.md
# TOOLS.md
# USER.md
# IDENTITY.md
# HEARTBEAT.md
# DREAMS.md

# Temporary files
*.tmp
*.bak
*.swp
*~

# Build outputs
*.pdf
!templates/*.pdf
!immigration/*.pdf

# Keep these folders
# memory/ - committed for backup
# content/ - committed
# wiki/ - Memory Palace, committed
# stocks/ - trading data, committed
# research/ - research, committed
# templates/ - templates (except auto-generated PDFs)
# immigration/ - immigration docs, committed



# Ignore Smart Environment folder
.smart-env-e 
# Runtime state (generated)
memory/agent-ready.md
memory/current_task_state.md
memory/resume-point.md

# Stock agent runtime (local only)
kb/stocks/agent/*.json
kb/stocks/agent/*.log
kb/stocks/agent/*.txt
