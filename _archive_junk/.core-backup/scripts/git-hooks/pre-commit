#!/bin/bash
# Pre-commit hook - validate commit message format
# Install to: .git/hooks/pre-commit

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional commit pattern
PATTERN="^(feat|fix|docs|update|chore|refactor|test|style): .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "❌ Invalid commit message format."
    echo "   Use: feat: description, fix: description, docs: description"
    echo "   Example: feat: Add new skill"
    exit 1
fi

echo "✅ Commit message validated"
exit 0